# Example users file for Authelia.
# Create hashed passwords with: authelia hash-password 'yourpassword'
# Docs: https://www.authelia.com/reference/guides/passwords/

users:
  admin:
    displayname: "OmniStream Admin"
    # Replace with a real argon2id hash.
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_ME$REPLACE_ME"
    email: "admin@example.com"
    groups:
      - admins
