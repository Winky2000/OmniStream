# Authelia configuration example for:
#   - Portal:   https://auth.omnistream.winkys.com
#   - App:      https://omnistream.winkys.com
#
# IMPORTANT: Replace all CHANGE_ME_* secrets before use.
# Docs: https://www.authelia.com/configuration/

server:
  address: tcp://0.0.0.0:9091/

log:
  level: info

identity_validation:
  reset_password:
    jwt_secret: "CHANGE_ME_jwt_secret_please"

default_redirection_url: "https://omnistream.winkys.com/"

authentication_backend:
  file:
    path: /config/users_database.yml

access_control:
  default_policy: deny
  rules:
    - domain: "omnistream.winkys.com"
      policy: two_factor

session:
  name: authelia_session
  secret: "CHANGE_ME_session_secret_please"
  expiration: 6h
  inactivity: 30m
  cookies:
    - domain: "omnistream.winkys.com"
      authelia_url: "https://auth.omnistream.winkys.com"
      default_redirection_url: "https://omnistream.winkys.com/"
      same_site: lax
      # Use secure cookies on HTTPS.
      insecure: false

storage:
  local:
    path: /config/db.sqlite3
  encryption_key: "CHANGE_ME_storage_encryption_key_please"

notifier:
  filesystem:
    filename: /config/notification.txt
